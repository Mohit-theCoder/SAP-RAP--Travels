projection;
strict ( 2 );

define behavior for ZAT_M_TRAVEL_P //alias <alias_name>
{
  use create;
  use update;
  use delete;

  use association _booking { create; }
}

define behavior for ZATS_M_BOOKING_P //alias <alias_name>
{
  use update;
  use delete;

  use association _Travel;
  use association _BookingSuppl { create; }
}

define behavior for ZATS_M_BOOKSUPPL_P //alias <alias_name>
{
  use update;
  use delete;

  use association _Travel;
  use association _Booking;
}